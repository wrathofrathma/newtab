{
  "name": "cattab",
  "private": true,
  "version": "1.0.1",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:ext": "node scripts/build-extensions.mjs all",
    "build:ext:chrome": "node scripts/build-extensions.mjs chrome",
    "build:ext:firefox": "node scripts/build-extensions.mjs firefox",
    "deploy:pages": "pnpm build && wrangler pages deploy dist --project-name \"${CF_PAGES_PROJECT:-newtab}\" --branch main",
    "deploy:pages:skip-build": "wrangler pages deploy dist --project-name \"${CF_PAGES_PROJECT:-newtab}\" --branch main",
    "preview": "vite preview",
    "prepare": "husky install"
  },
  "dependencies": {
    "pinia": "3.0.4",
    "prepend-http": "4.0.0",
    "vue": "3.5.30",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-vue": "6.0.5",
    "autoprefixer": "10.4.27",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.2",
    "vue-tsc": "3.2.6",
    "wrangler": "^4.77.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
